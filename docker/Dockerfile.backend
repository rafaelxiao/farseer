FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy project files
COPY pyproject.toml uv.lock ./
COPY src ./src
COPY migrations ./migrations
COPY alembic.ini .

# Install dependencies
RUN uv sync --frozen --no-dev

# Default port (overridden by env)
EXPOSE 8173 8174

# Run migrations and start server
CMD ["sh", "-c", "uv run alembic upgrade head && uv run uvicorn farseer.main:app --host 0.0.0.0 --port ${PORT:-8173}"]
